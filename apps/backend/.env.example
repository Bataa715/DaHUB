# Backend local dev — Docker ашиглахгүй үед
# Docker ашиглах үед root/.env файл ашиглана

PORT=3001
NODE_ENV=development
JWT_SECRET=CHANGE_THIS_TO_A_LONG_RANDOM_STRING_AT_LEAST_32_CHARS

# Frontend URL — CORS зөвшөөрөх (FRONTEND_URL-тай адил байх)
CORS_ORIGINS=http://localhost:9002

# ClickHouse
CLICKHOUSE_HOST=http://localhost:8123
CLICKHOUSE_HTTPS_HOST=https://localhost:8443
CLICKHOUSE_USER=audit_app
CLICKHOUSE_PASSWORD=
CLICKHOUSE_DATABASE=audit_db

CREDENTIAL_ENCRYPTION_KEY="your_64_character_hex_key_here"
